{
  "version": 2,
  "buildCommand": "cd LP1 && npm install && npm run build",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/LP1/assets/:path*", "destination": "/LP1/dist/assets/:path*" },
    { "source": "/LP1", "destination": "/LP1/dist/index.html" },
    { "source": "/LP1/", "destination": "/LP1/dist/index.html" }
  ]
}
